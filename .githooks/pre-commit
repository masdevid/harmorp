#!/usr/bin/env bash
set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

pass() { echo -e "${GREEN}✓${NC} $1"; }
fail() { echo -e "${RED}✗${NC} $1"; exit 1; }
warn() { echo -e "${YELLOW}!${NC} $1"; }

echo "Running pre-commit checks for harmorp..."

# 1. Formatting
if ! cargo fmt --check 2>/dev/null; then
    fail "cargo fmt: unformatted code detected. Run 'cargo fmt' to fix."
fi
pass "cargo fmt"

# 2. Clippy
if ! cargo clippy -- -D warnings 2>&1 | grep -q "^error"; then
    pass "cargo clippy"
else
    cargo clippy -- -D warnings
    fail "cargo clippy: warnings treated as errors"
fi

# 3. Proprietary reference guard
VIOLATIONS=$(grep -rn "KBBI\|kbbi\|harmorph_stemmer" src/ tests/ benches/ examples/ README.md Cargo.toml 2>/dev/null || true)
if [ -n "$VIOLATIONS" ]; then
    echo "$VIOLATIONS"
    fail "Proprietary references found (old package name or other proprietary terms) — remove before committing to public repo"
fi
pass "proprietary reference guard"

# 4. Tests
if ! cargo test 2>&1 | tail -5 | grep -q "^test result: ok"; then
    cargo test
    fail "cargo test: tests failed"
fi
pass "cargo test"

echo ""
echo -e "${GREEN}All checks passed.${NC}"
